// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
    id Int @id @default(autoincrement())
    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    login String @unique
    password String?
}

model Person {
    id Int @id @default(autoincrement())
    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    firstName String
    secondName String?
    lastName String?

    personnelNumber Int? @unique // табльный номер
    accessGroup Int // группа доступа
    departmentID  Int // подразделение

    // Похоже лишнее
    // IdentifierID Int @default(autoincrement()) @unique

    advanced String?

    identifiers Identifier[]

    @@map("persons")
}

model Identifier {
    id Int @id @default(autoincrement())
    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    personID Int // TODO: @notnull - надо подумать
    person Person @relation(fields: [personID], references: [id])

    identifier String @unique

    @@map("identifiers")
}